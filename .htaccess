Options -MultiViews
DirectoryIndex index.html
ErrorDocument 404 /404.html

RewriteEngine On

# Serve 404.html for /404 clean URL
RewriteRule ^404$ /404.html [L]

# Slug correction: redirect page files to their hash-based routes
RewriteRule ^pages/home\.html$            /\#home             [R=302,L,NE]
RewriteRule ^pages/about\.html$           /\#about            [R=302,L,NE]
RewriteRule ^pages/contact\.html$         /\#contact          [R=302,L,NE]
RewriteRule ^pages/portfolio\.html$       /\#portfolio        [R=302,L,NE]
RewriteRule ^pages/single-project\.html$  /\#single-project   [R=302,L,NE]

# Redirect every .html request to /index.html, except /index.html itself
RewriteCond %{REQUEST_URI} !^/index\.html$ [NC]
RewriteCond %{REQUEST_URI} \.html$ [NC]
RewriteRule ^ /index.html [R=302,L]